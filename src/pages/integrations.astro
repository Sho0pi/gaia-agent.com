---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

// All facts sourced from docs.gaia-agent.com (llms-full.txt), not landing copy.
// badge: 'built-in' (shipping today) | 'via mcp' | 'coming soon'
const channels = [
  { name: 'Terminal', icon: 'simple-icons:gnometerminal', badge: 'built-in', cmd: 'gaia', blurb: 'Inline chat in your shell. Always on, always admin.' },
  { name: 'Telegram', icon: 'simple-icons:telegram', badge: 'built-in', cmd: 'gaia connect telegram', blurb: 'Pair a bot via BotFather and text Gaia from your phone.' },
  { name: 'WhatsApp', icon: 'simple-icons:whatsapp', badge: 'built-in', cmd: 'gaia connect whatsapp', blurb: 'Scan a QR and message Gaia like any other contact.' },
  { name: 'Discord', icon: 'simple-icons:discord', badge: 'coming soon', cmd: null, blurb: 'Channels, DMs, and slash commands. On the roadmap.' },
  { name: 'Slack', icon: 'simple-icons:slack', badge: 'coming soon', cmd: null, blurb: 'Workspace events and app actions. On the roadmap.' },
];

const models = [
  { name: 'Google Gemini', icon: 'simple-icons:googlegemini', badge: 'built-in · default', cmd: 'GEMINI_API_KEY', blurb: 'The default provider, with a free-tier embedding model out of the box.' },
  { name: 'OpenAI', icon: 'simple-icons:openai', badge: 'built-in', cmd: 'OPENAI_API_KEY · --oauth', blurb: 'GPT models with text-embedding-3-small for memory. Attach an API key, or sign in with your ChatGPT subscription via gaia model --oauth.' },
  { name: 'Anthropic Claude', icon: 'simple-icons:anthropic', badge: 'built-in', cmd: 'ANTHROPIC_API_KEY', blurb: 'Claude family models as a first-class provider.' },
  { name: 'OpenRouter', icon: 'simple-icons:openrouter', badge: 'built-in', cmd: 'OPENROUTER_API_KEY', blurb: 'One key, hundreds of models routed through a single gateway.' },
  { name: 'Local models', icon: 'simple-icons:ollama', badge: 'coming soon', cmd: null, blurb: 'Run open-weight models on your own box with Ollama.' },
];

// Real tool families and their function names (capability-gated via gaia.acl).
const tools = [
  { title: 'File system', ico: 'fs', fns: ['fs_read', 'fs_write', 'fs_delete'], blurb: 'Sandboxed reads and writes, scoped per soul.' },
  { title: 'Shell', ico: 'shell', fns: ['run_command'], blurb: 'Run real commands, gated to the user role and above.' },
  { title: 'Web & browser', ico: 'web', fns: ['web_search', 'web_fetch', 'browser_screenshot'], blurb: 'Search, fetch, and screenshot live pages.' },
  { title: 'Memory', ico: 'memory', fns: ['load_memory', 'remember'], blurb: 'Recall and persist what matters across sessions.' },
  { title: 'Multi-agent', ico: 'agents', fns: ['delegate_to_soul', 'consult_soul', 'task_create'], blurb: 'Hand work to specialist souls and stitch results back.' },
  { title: 'Scheduling', ico: 'clock', fns: ['cron', 'schedule'], blurb: 'Wake up on a timer and run jobs in the background.' },
];

const platforms = [
  { name: 'macOS', icon: 'simple-icons:apple', note: 'launchd boot service' },
  { name: 'Linux', icon: 'simple-icons:linux', note: 'systemd boot service' },
  { name: 'Windows', icon: 'simple-icons:windows', note: 'via WSL' },
];
---
<Layout
  title="Integrations · everything Gaia plugs into"
  description="The channels, models, tools, and skills Gaia connects to: Telegram, WhatsApp, Gemini, OpenAI, MCP servers, and the toolset every soul inherits."
  active="integrations"
>

<style is:global>
  /* Reuse the homepage card so tiles feel native to the site. */
  .card { background:var(--surface); border:1px solid var(--rule); border-radius:0; transition: transform .35s cubic-bezier(.2,.8,.2,1), border-color .25s; }
  .card:hover { transform:translateY(-2px); border-color:var(--moss); }
  .ico { stroke:var(--ink); stroke-width:1.25; fill:none; stroke-linecap:round; stroke-linejoin:round; }
  .card:hover .ico { stroke:var(--moss); }

  /* Integration tile */
  .intg { display:flex; flex-direction:column; padding:1.5rem 1.45rem; position:relative; min-height:188px; }
  .intg .logo {
    width:42px; height:42px; display:flex; align-items:center; justify-content:center;
    border:1px solid var(--rule); background:color-mix(in srgb, var(--moss) 6%, var(--bg));
    color:var(--ink); transition:color .25s, border-color .25s;
  }
  .card:hover .intg .logo { color:var(--moss); border-color:var(--moss); }
  .intg.soon { opacity:.82; }
  .intg.soon .logo { color:var(--ink-soft); }
  .intg h3 { font-family:'Fraunces',serif; font-size:1.15rem; margin-top:1rem; color:var(--ink); }
  .intg p { color:var(--ink-soft); font-size:.86rem; line-height:1.55; margin-top:.5rem; }
  .intg .cmd {
    margin-top:auto; padding-top:.85rem; font-family:'JetBrains Mono',monospace;
    font-size:.72rem; color:var(--moss);
  }
  .intg .cmd::before { content:"$ "; opacity:.5; }

  /* Badge pill */
  .badge {
    position:absolute; top:1.45rem; right:1.45rem;
    font-family:'Cinzel',serif; font-weight:500; font-size:.58rem;
    letter-spacing:.16em; text-transform:uppercase; padding:.25rem .55rem;
    border:1px solid var(--moss); color:var(--moss); white-space:nowrap;
    background:color-mix(in srgb, var(--moss) 8%, transparent);
  }
  .badge.soon { border:1px dashed var(--rule); color:var(--ink-soft); background:transparent; }

  /* Function-name chips (mirrors index .agent-tools span) */
  .fns { margin-top:.95rem; display:flex; flex-wrap:wrap; gap:.4rem; }
  .fns span {
    border:1px solid color-mix(in srgb, var(--rule) 85%, transparent);
    padding:.24rem .48rem; font-family:'JetBrains Mono',monospace; font-size:.66rem;
    color:var(--ink-soft); background:color-mix(in srgb, var(--bg) 72%, transparent);
  }

  /* Platform tile */
  .plat { display:flex; align-items:center; gap:1rem; padding:1.4rem 1.45rem; }
  .plat .logo { width:34px; height:34px; color:var(--ink); transition:color .25s; }
  .card:hover .plat .logo { color:var(--moss); }
  .plat .pname { font-family:'Fraunces',serif; font-size:1.1rem; color:var(--ink); }
  .plat .pnote { font-family:'JetBrains Mono',monospace; font-size:.7rem; color:var(--ink-soft); margin-top:.15rem; }
</style>

<main class="relative z-10 max-w-5xl mx-auto px-6 pt-20 pb-12 md:pt-24 text-center">
  <p class="eyebrow">Γαῖα · what it connects to</p>
  <h1 class="display mt-6 text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.05] tracking-tight max-w-3xl mx-auto">
    Everything your souls<br/><span class="italic" style="color:var(--moss);">can reach.</span>
  </h1>
  <p class="muted text-[15px] mt-6 max-w-lg mx-auto leading-relaxed">
    Gaia runs on the apps you already text on, the models you already pay for, and the tools every soul inherits the moment it's forged. Bring your own keys, self-host the whole thing.
  </p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
    <a href="https://docs.gaia-agent.com" target="_blank" data-umami-event="read-docs" class="btn btn-primary">Read the docs <span aria-hidden="true">↗</span></a>
    <a href="https://github.com/sho0pi/gaia" target="_blank" data-umami-event="star-github" class="btn btn-ghost"><span style="color:var(--gold);">★</span> Star the repo</a>
  </div>
</main>

<section class="relative z-10 max-w-5xl mx-auto px-6 pb-16">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-0 border border-[color:var(--rule)]">
    <div class="stat-block border-r border-[color:var(--rule)] p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">3</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">Channels</div>
    </div>
    <div class="stat-block border-r border-[color:var(--rule)] p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">4</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">Model providers</div>
    </div>
    <div class="stat-block border-r border-[color:var(--rule)] p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">∞</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">Skills + MCP</div>
    </div>
    <div class="stat-block p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">3</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">Platforms</div>
    </div>
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<!-- I · Channels -->
<section class="relative z-10 max-w-5xl mx-auto px-6 py-20">
  <div class="md:flex items-end justify-between gap-10 mb-12">
    <div>
      <p class="eyebrow">I · Channels</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">Talk to it anywhere.</h2>
    </div>
    <p class="muted text-[14px] max-w-sm mt-4 md:mt-0 leading-relaxed">One command pairs a channel. Gaia answers from your server while you message from your phone.</p>
  </div>
  <div class="grid sm:grid-cols-2 md:grid-cols-3">
    {channels.map((c, i) => (
      <article class={`card intg ${c.badge === 'coming soon' ? 'soon' : ''} ${i % 3 !== 2 ? 'md:border-r-0' : ''} ${i % 2 === 0 ? 'sm:border-r-0 md:border-r' : ''} ${i < channels.length - (channels.length % 3 || 3) ? 'border-b-0' : ''}`}>
        <span class={`badge ${c.badge === 'coming soon' ? 'soon' : ''}`}>{c.badge}</span>
        <span class="logo"><Icon name={c.icon} width="22" height="22" /></span>
        <h3>{c.name}</h3>
        <p>{c.blurb}</p>
        {c.cmd && <div class="cmd">{c.cmd}</div>}
      </article>
    ))}
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<!-- II · Models -->
<section class="relative z-10 max-w-5xl mx-auto px-6 py-20">
  <div class="md:flex items-end justify-between gap-10 mb-12">
    <div>
      <p class="eyebrow">II · Models</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">Bring your own brain.</h2>
    </div>
    <p class="muted text-[14px] max-w-sm mt-4 md:mt-0 leading-relaxed">Set a provider with <span class="mono" style="color:var(--moss);">gaia model</span> or the <span class="mono" style="color:var(--moss);">llm</span> block in <span class="mono">gaia.yaml</span>. Give each soul its own.</p>
  </div>
  <div class="grid sm:grid-cols-2 md:grid-cols-3">
    {models.map((m, i) => (
      <article class={`card intg ${m.badge === 'coming soon' ? 'soon' : ''} ${i % 3 !== 2 ? 'md:border-r-0' : ''} ${i % 2 === 0 ? 'sm:border-r-0 md:border-r' : ''} ${i < models.length - (models.length % 3 || 3) ? 'border-b-0' : ''}`}>
        <span class={`badge ${m.badge === 'coming soon' ? 'soon' : ''}`}>{m.badge}</span>
        <span class="logo"><Icon name={m.icon} width="22" height="22" /></span>
        <h3>{m.name}</h3>
        <p>{m.blurb}</p>
        {m.cmd && <div class="cmd">{m.cmd}</div>}
      </article>
    ))}
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<!-- III · Tools every soul carries -->
<section class="relative z-10 max-w-5xl mx-auto px-6 py-20">
  <div class="md:flex items-end justify-between gap-10 mb-12">
    <div>
      <p class="eyebrow">III · Built-in tools</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">What every soul carries.</h2>
    </div>
    <p class="muted text-[14px] max-w-sm mt-4 md:mt-0 leading-relaxed">A real toolset, not a sandbox. Every call is gated by a capability ACL, so guests, users, and admins reach exactly what they should.</p>
  </div>
  <div class="grid md:grid-cols-3">
    {tools.map((t, i) => (
      <article class={`card p-7 ${i % 3 !== 2 ? 'md:border-r-0' : ''} ${i < 3 ? 'border-b-0' : ''}`}>
        {t.ico === 'fs' && <svg class="ico" width="34" height="34" viewBox="0 0 32 32"><path d="M4 8h9l2 3h13v13H4z"/><path d="M4 13h24"/></svg>}
        {t.ico === 'shell' && <svg class="ico" width="34" height="34" viewBox="0 0 32 32"><rect x="4" y="6" width="24" height="20"/><path d="M9 13l4 3-4 3M16 19h7"/></svg>}
        {t.ico === 'web' && <svg class="ico" width="34" height="34" viewBox="0 0 32 32"><circle cx="16" cy="16" r="11"/><path d="M5 16h22M16 5c4 4 4 18 0 22M16 5c-4 4-4 18 0 22"/></svg>}
        {t.ico === 'memory' && <svg class="ico" width="34" height="34" viewBox="0 0 32 32"><path d="M16 4c0 6-6 8-6 14a6 6 0 0012 0c0-6-6-8-6-14z"/><path d="M10 18c2 0 4 1 6 3M22 18c-2 0-4 1-6 3"/></svg>}
        {t.ico === 'agents' && <svg class="ico" width="34" height="34" viewBox="0 0 32 32"><circle cx="16" cy="8" r="3"/><circle cx="8" cy="22" r="3"/><circle cx="24" cy="22" r="3"/><path d="M16 11v4M14 17l-4 3M18 17l4 3"/></svg>}
        {t.ico === 'clock' && <svg class="ico" width="34" height="34" viewBox="0 0 32 32"><circle cx="16" cy="16" r="11"/><path d="M16 9v7l5 3"/></svg>}
        <h3 class="display text-xl mt-5">{t.title}</h3>
        <p class="muted text-sm mt-3 leading-relaxed">{t.blurb}</p>
        <div class="fns">{t.fns.map((f) => <span>{f}</span>)}</div>
      </article>
    ))}
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<!-- IV · Skills & MCP -->
<section class="relative z-10 max-w-5xl mx-auto px-6 py-20">
  <div class="text-center mb-12">
    <p class="eyebrow">IV · Skills & MCP</p>
    <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">New abilities, in a file.</h2>
  </div>
  <div class="grid md:grid-cols-2">
    <article class="card p-7 border-b-0 md:border-r-0">
      <svg class="ico" width="36" height="36" viewBox="0 0 32 32"><path d="M9 4h10l5 5v19H9z"/><path d="M18 4v6h6M13 17h8M13 21h8M13 13h4"/></svg>
      <h3 class="display text-xl mt-5">Skills</h3>
      <p class="muted text-sm mt-3 leading-relaxed">Plain-text playbooks. A <span class="mono">SKILL.md</span> folder under <span class="mono">~/.gaia/skills/</span> teaches a soul something once, then sticks. Gaia loads them on demand, so it only reads the full text when a skill is actually relevant.</p>
      <div class="fns">
        <span>gaia skill list</span><span>gaia skill new</span><span>gaia skill install</span><span>gaia grow run</span>
      </div>
    </article>
    <article class="card p-7 border-b-0">
      <svg class="ico" width="36" height="36" viewBox="0 0 32 32"><circle cx="8" cy="8" r="3"/><circle cx="24" cy="8" r="3"/><circle cx="16" cy="24" r="3"/><path d="M8 11v4a4 4 0 004 4h0M24 11v4a4 4 0 01-4 4h0M16 19v2"/></svg>
      <h3 class="display text-xl mt-5">MCP servers</h3>
      <p class="muted text-sm mt-3 leading-relaxed">Wire up any custom Model Context Protocol server through <span class="mono">gaia tools</span> and its capabilities become tools your souls can call. The browser itself can run on a <span class="mono">playwright-mcp</span> backend.</p>
      <div class="fns">
        <span>gaia tools</span><span>custom mcp</span><span>playwright-mcp</span>
      </div>
    </article>
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<!-- V · Run anywhere -->
<section class="relative z-10 max-w-5xl mx-auto px-6 py-20">
  <div class="md:flex items-end justify-between gap-10 mb-12">
    <div>
      <p class="eyebrow">V · Run anywhere</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">Your machine. Your rules.</h2>
    </div>
    <p class="muted text-[14px] max-w-sm mt-4 md:mt-0 leading-relaxed">Self-hosted by design. State lives in <span class="mono">~/.gaia/</span>, nothing phones home but the model call you set up.</p>
  </div>
  <div class="grid sm:grid-cols-3">
    {platforms.map((p, i) => (
      <article class={`card plat ${i < platforms.length - 1 ? 'sm:border-r-0 border-b-0 sm:border-b' : ''}`}>
        <span class="logo"><Icon name={p.icon} width="30" height="30" /></span>
        <div>
          <div class="pname">{p.name}</div>
          <div class="pnote">{p.note}</div>
        </div>
      </article>
    ))}
  </div>
  <div class="mono text-[13px] muted mt-8 text-center leading-relaxed">
    <span style="color:var(--moss);">gaia start</span> runs the daemon · <span style="color:var(--moss);">gaia service install</span> survives reboots · memory in a local Chroma store · multi-user via <span style="color:var(--moss);">users.json</span> RBAC
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<!-- CTA -->
<section class="relative z-10 max-w-5xl mx-auto px-6 py-24">
  <div class="grid md:grid-cols-12 gap-10 items-end">
    <div class="md:col-span-7">
      <p class="eyebrow">Plant a goal</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">Wire it up. <span class="italic" style="color:var(--moss);">See what grows.</span></h2>
      <p class="muted text-[15px] mt-5 max-w-md leading-relaxed">Free and open source. Bring your keys, pick your channels, and let Gaia forge the souls that use them.</p>
    </div>
    <div class="md:col-span-5 flex flex-col gap-3">
      <a href="https://docs.gaia-agent.com" target="_blank" data-umami-event="read-docs" class="btn btn-primary justify-between">Read the docs <span aria-hidden="true">↗</span></a>
      <a href="https://github.com/sho0pi/gaia" target="_blank" data-umami-event="star-github" class="btn btn-ghost justify-between">Star the repo <span aria-hidden="true">↗</span></a>
    </div>
  </div>
</section>

</Layout>
