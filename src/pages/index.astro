---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---
<Layout
  title="Gaia: agents that build agents"
  description="Gaia is an open-source AI agent that hands work to specialist souls, and builds new ones when nothing fits."
  active="home"
>

<style is:global>
  /* === Glitch swap — linear timing (not steps) === */
  .glitch-wrap { position:relative; display:inline-block; line-height:1; padding-right:.35em; font-size:1.2em; vertical-align:baseline; }
  .glitch-wrap .gw-en, .glitch-wrap .gw-gr { color:var(--ink); display:inline-block; }
  .glitch-wrap .gw-en { font-family:'Fraunces',serif; font-weight:700; font-style:italic; font-variation-settings:"opsz" 144,"SOFT" 100; letter-spacing:-0.04em; }
  .glitch-wrap .gw-gr { font-family:'Cinzel',serif; font-weight:900; position:absolute; left:0; top:0; opacity:0; letter-spacing:.02em; }
  .glitch-wrap.glitching .gw-en { animation: glitch-out 10s linear infinite; }
  .glitch-wrap.glitching .gw-gr { animation: glitch-in  10s linear infinite; }
  @keyframes glitch-out {
    0%,73%  { opacity:1; transform:translate(0,0); clip-path:inset(0 0 0 0); }
    74%     { opacity:1; transform:translate(2px,-1px); clip-path:inset(0 0 60% 0); }
    75%     { opacity:1; transform:translate(-2px,1px); clip-path:inset(40% 0 0 0); }
    76%     { opacity:.4; }
    77%,96% { opacity:0; }
    97%     { opacity:.4; clip-path:inset(0 0 50% 0); }
    98%     { opacity:.7; clip-path:inset(50% 0 0 0); }
    99%,100%{ opacity:1; transform:translate(0,0); clip-path:inset(0 0 0 0); }
  }
  @keyframes glitch-in {
    0%,76%  { opacity:0; }
    77%     { opacity:.6; clip-path:inset(0 0 50% 0); }
    78%     { opacity:.8; clip-path:inset(50% 0 0 0); }
    79%,96% { opacity:1; clip-path:inset(0 0 0 0); }
    97%     { opacity:.7; clip-path:inset(0 0 60% 0); }
    98%     { opacity:.4; clip-path:inset(40% 0 0 0); }
    99%,100%{ opacity:0; }
  }

  /* === Verb cycle === */
  .verb-cycle { display:inline-block; position:relative; }
  .verb-cycle .verb {
    display:inline-block; color:var(--moss);
    font-family:'Fraunces',serif; font-weight:600; font-style:italic;
    transition: opacity .4s ease, transform .4s ease, filter .4s ease;
  }
  .verb-cycle .verb.out { opacity:0; transform:translateY(-8px); filter:blur(3px); }
  .verb-cycle .verb.in  { opacity:0; transform:translateY(10px); filter:blur(3px); }

  /* === Example slot machine — "need X → a specialist" === */
  .ex-band {
    display:flex; flex-wrap:wrap; align-items:center; justify-content:center;
    gap:.5rem .65rem; font-family:'Fraunces',serif;
    font-size:clamp(1.05rem,2.6vw,1.6rem); line-height:1.5;
  }
  .ex-lead { color:var(--ink-soft); }
  .ex-arrow { color:var(--kelp); font-family:'Cinzel',serif; }
  /* reel = 2-row window: active pick centered, neighbours half-peek and fade at the edges */
  .reel {
    position:relative; display:inline-block; overflow:hidden;
    height:3em; vertical-align:middle;
    -webkit-mask-image:linear-gradient(180deg, transparent 0%, #000 34%, #000 66%, transparent 100%);
    mask-image:linear-gradient(180deg, transparent 0%, #000 34%, #000 66%, transparent 100%);
  }
  .reel-need { width:9em; }
  .reel-role { width:10.5em; }
  .reel-strip { display:flex; flex-direction:column; will-change:transform; }
  .reel-strip > span { height:1.5em; line-height:1.5em; text-align:center; white-space:nowrap; }
  .reel-need .reel-strip > span { color:var(--ink); font-weight:600; }
  .reel-role .reel-strip > span { color:var(--moss); font-style:italic; font-weight:600; }
  /* faint payline framing the active row */
  .slot-line { position:relative; display:inline-block; }
  .slot-line::before, .slot-line::after {
    content:""; position:absolute; left:0; right:0; height:1px;
    background:color-mix(in srgb, var(--rule) 70%, transparent); pointer-events:none;
  }
  .slot-line::before { top:calc(50% - .75em); }
  .slot-line::after  { top:calc(50% + .75em); }

  .card { background:var(--surface); border:1px solid var(--rule); border-radius:0; transition: transform .35s cubic-bezier(.2,.8,.2,1), border-color .25s; }
  .card:hover { transform:translateY(-2px); border-color:var(--moss); }

  .drop { font-family:'Cinzel',serif; font-weight:900; color:var(--moss); opacity:.18; line-height:.85; user-select:none; }

  /* Terminal shell block — parchment in light theme, phosphor green in dark */
  .shell-wrap { position:relative; border:1px solid var(--rule); box-shadow:0 24px 60px -32px color-mix(in srgb, var(--ink) 45%, transparent); }
  .shell-bar { position:relative; display:flex; align-items:center; padding:.6rem 1rem; background:var(--bg-deep); border-bottom:1px solid var(--rule); }
  .shell-dots { display:flex; gap:.5rem; }
  .shell-dot { width:11px; height:11px; border-radius:50%; box-shadow:inset 0 1px 1px rgba(255,255,255,.25), inset 0 -1px 1px rgba(0,0,0,.25); }
  .shell-dot.r { background:#ff5f57; } .shell-dot.y { background:#febc2e; } .shell-dot.g { background:#28c840; }
  .shell-title { position:absolute; left:50%; transform:translateX(-50%); font-family:'JetBrains Mono',monospace; font-size:.68rem; letter-spacing:.1em; color:color-mix(in srgb, var(--ink) 45%, transparent); user-select:none; }
  .copy-btn {
    margin-left:auto; font-family:'JetBrains Mono',monospace; font-size:.68rem;
    color:var(--ink-soft); background:color-mix(in srgb, var(--ink) 5%, transparent);
    border:1px solid var(--rule); padding:.25rem .6rem;
    cursor:pointer; border-radius:0; transition:all .15s;
  }
  .copy-btn:hover { background:color-mix(in srgb, var(--ink) 12%, transparent); color:var(--ink); border-color:var(--ink-soft); }
  .copy-btn.copied { color:var(--moss); border-color:var(--moss); background:color-mix(in srgb, var(--moss) 10%, transparent); }
  .vellum { font-family:'JetBrains Mono',monospace; font-size:.88rem; line-height:1.7; background:var(--surface); padding:1.5rem 1.75rem; color:var(--ink-soft); }
  .vellum .p { color:var(--moss); font-weight:600; } .vellum .c { color:var(--ink); } .vellum .ok { color:var(--moss); }
  .vellum .dim { color:color-mix(in srgb, var(--ink-soft) 65%, transparent); }
  .cursor { display:inline-block; width:8px; height:1em; background:var(--moss); vertical-align:text-bottom; margin-left:3px; animation:cursor-blink 1.1s steps(2,start) infinite; }
  @keyframes cursor-blink { 50% { opacity:0; } }
  @media (prefers-reduced-motion: reduce) { .cursor { animation:none; } }

  [data-theme="dark"] .shell-wrap { box-shadow:0 24px 60px -28px rgba(0,0,0,.85); }
  [data-theme="dark"] .shell-bar { background:#0A1610; border-bottom:1px solid rgba(255,255,255,.06); }
  [data-theme="dark"] .shell-title { color:rgba(226,250,232,.35); }
  [data-theme="dark"] .copy-btn { color:rgba(226,250,232,.5); background:rgba(255,255,255,.06); border-color:rgba(255,255,255,.12); }
  [data-theme="dark"] .copy-btn:hover { background:rgba(255,255,255,.12); color:#fff; border-color:rgba(255,255,255,.25); }
  [data-theme="dark"] .copy-btn.copied { color:var(--glow); border-color:var(--glow); background:rgba(34,240,168,.08); }
  [data-theme="dark"] .vellum { background:#0d1a10; color:#8BAF94; }
  [data-theme="dark"] .vellum .p, [data-theme="dark"] .vellum .ok { color:#4ADE80; }
  [data-theme="dark"] .vellum .c { color:#E2FAE8; }
  [data-theme="dark"] .vellum .dim { color:#5a7a62; }
  [data-theme="dark"] .cursor { background:#4ADE80; }

  .live { width:7px; height:7px; border-radius:9999px; background:var(--glow); box-shadow:0 0 0 0 var(--glow); animation: live-pulse 2.4s ease-out infinite; }
  @keyframes live-pulse {
    0%   { box-shadow:0 0 0 0 color-mix(in srgb, var(--glow) 60%, transparent); }
    100% { box-shadow:0 0 0 10px transparent; }
  }

  .ico { stroke:var(--ink); stroke-width:1.25; fill:none; stroke-linecap:round; stroke-linejoin:round; }
  .card:hover .ico { stroke:var(--moss); }

  .smith { background:var(--surface); border:1px solid var(--rule); padding:2.25rem 2rem; position:relative; }
  .smith-grid { display:grid; grid-template-columns:1fr; gap:1.5rem; font-family:'JetBrains Mono',monospace; font-size:.78rem; color:var(--ink-soft); }
  .node { display:flex; align-items:center; gap:.85rem; padding:.7rem 1rem; border:1px solid var(--rule); background:var(--bg); }
  .node .label { color:var(--ink); }
  .node .role { color:var(--moss); font-style:italic; font-family:'Fraunces',serif; font-size:.92rem; font-weight:500; }
  .arrow { text-align:center; color:var(--moss); font-family:'Cinzel',serif; font-size:.8rem; letter-spacing:.3em; padding:.25rem 0; }
  .arrow::before { content:"│"; display:block; opacity:.3; margin-bottom:.25rem; }
  .arrow::after  { content:"│"; display:block; opacity:.3; margin-top:.25rem; }

  blockquote.dictum { border-left:2px solid var(--moss); padding:.4rem 0 .4rem 1.25rem; font-family:'Fraunces',serif; font-style:italic; font-weight:400; font-size:1.05rem; color:var(--ink-soft); line-height:1.5; }

  /* Star count badge */
  .star-badge {
    display:inline-flex; align-items:center; gap:.5rem;
    border:1px solid var(--rule); padding:.35rem .85rem;
    font-family:'JetBrains Mono',monospace; font-size:.78rem;
    color:var(--ink-soft); background:var(--surface);
    transition: border-color .2s, color .2s;
    text-decoration:none;
  }
  .star-badge:hover { border-color:var(--moss); color:var(--ink); }
  .star-badge .star-ico { color:var(--gold); }
  .star-badge .star-num { color:var(--ink); font-weight:600; }

  /* Stats bar */
  .stat-block { transition: background .2s; }
  .stat-block:hover { background: color-mix(in srgb, var(--moss) 5%, transparent); }

  /* How it works */
  .how-num {
    display:inline-block; font-family:'Cinzel',serif; font-weight:700;
    font-size:.75rem; letter-spacing:.2em;
    border:1px solid var(--rule); padding:.3rem .6rem; color:var(--ink-soft);
  }
  .how-active { background: color-mix(in srgb, var(--moss) 5%, transparent); }
  .how-active .how-num { color:var(--moss); border-color:var(--moss); }

  /* FAQ */
  .faq-item { border-bottom:1px solid var(--rule); }
  .faq-item:first-child { border-top:1px solid var(--rule); }
  .faq-q {
    width:100%; display:flex; justify-content:space-between; align-items:center;
    cursor:pointer; padding:1.1rem 0; list-style:none;
    font-size:.95rem; font-weight:500; color:var(--ink); text-align:left; gap:1rem;
  }
  .faq-q::-webkit-details-marker { display:none; }
  .faq-icon { font-size:1.2rem; color:var(--moss); flex-shrink:0; transition:transform .2s; }
  .faq-item[open] .faq-icon { transform:rotate(45deg); }
  .faq-a {
    padding:0 0 1.1rem; color:var(--ink-soft);
    font-size:.9rem; line-height:1.7;
  }

  /* Voices — testimonials + tweet wall */
  .quote-card { background:var(--surface); border:1px solid var(--rule); padding:1.6rem 1.5rem; display:flex; flex-direction:column; transition:border-color .25s, transform .35s cubic-bezier(.2,.8,.2,1); }
  .quote-card:hover { border-color:var(--moss); transform:translateY(-2px); }
  .quote-card .mark { font-family:'Cinzel',serif; font-weight:900; font-size:1.6rem; line-height:.6; color:var(--moss); opacity:.5; }
  .quote-card blockquote { font-family:'Fraunces',serif; font-size:1rem; line-height:1.55; color:var(--ink); margin:.9rem 0 1.25rem; }
  .quote-card .who { margin-top:auto; display:flex; align-items:center; gap:.7rem; }
  .quote-card .avatar { width:34px; height:34px; border-radius:50%; background:color-mix(in srgb, var(--moss) 18%, var(--surface)); border:1px solid var(--rule); display:flex; align-items:center; justify-content:center; font-family:'Cinzel',serif; font-weight:700; font-size:.8rem; color:var(--moss); flex-shrink:0; }
  .quote-card .name { font-size:.82rem; font-weight:600; color:var(--ink); }
  .quote-card .handle { font-family:'JetBrains Mono',monospace; font-size:.72rem; color:var(--ink-soft); }
  /* Tweet wall (dormant until wired to X API/embed) */
  #tweetWall:empty { display:none; }
  .tweet-empty { border:1px dashed var(--rule); padding:1.5rem; text-align:center; color:var(--ink-soft); font-size:.84rem; }
</style>

<main class="relative z-10 max-w-5xl mx-auto px-6 pt-20 pb-24">
  <div class="grid md:grid-cols-12 gap-10 items-center">
    <div class="md:col-span-7">
      <p class="eyebrow">Γαῖα · agents that build agents</p>
      <h1 class="display mt-6 text-[clamp(3rem,7vw,5.6rem)] leading-[1.02] tracking-tight">
        Why do the task<br/>
        when you can <span class="verb-cycle"><span id="verb" class="verb">forge</span></span><br/>
        someone to do it?
      </h1>
      <div class="mt-10 flex items-start gap-6">
        <span class="drop text-[6.5rem] hidden sm:block" aria-hidden="true">Γ</span>
        <p class="muted max-w-md text-[15px] leading-relaxed pt-2">
          <span class="glitch-wrap glitching"><span class="gw-en">Gaia</span><span class="gw-gr" aria-hidden="true">Γαῖα</span></span>
          is a new kind of AI agent. Instead of doing every task itself, it builds the agents that do. It picks the right one for the job, makes a new one when nothing fits, and keeps making them better as they go.
        </p>
      </div>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a id="starBadge" href="https://github.com/sho0pi/gaia" target="_blank" class="btn btn-primary">
          <span style="color:var(--gold);">★</span>
          Star on GitHub
          <span class="star-num" id="starCount" style="color:inherit;opacity:.7;"></span>
        </a>
        <a href="#install" class="btn btn-ghost">Get started ↓</a>
      </div>
      <div class="mt-6 flex items-center gap-2 text-xs muted">
        <span class="live"></span> open source · MIT · runs on macOS, Linux, Windows
      </div>
    </div>
    <div class="md:col-span-5">
      <figure class="relative">
        <img src="/hero.jpg" alt="" class="w-full" style="border:1px solid var(--rule);" />
        <figcaption class="mono text-[10px] tracking-widest uppercase mt-3 muted">Fig. I · gaia, mother of agents</figcaption>
      </figure>
    </div>
  </div>
</main>

<section class="relative z-10 max-w-5xl mx-auto px-6 pt-8 pb-20 text-center">
  <p class="eyebrow mb-5">the gaia way</p>
  <h2 class="display text-3xl md:text-[2.6rem] leading-[1.1] tracking-tight max-w-2xl mx-auto">
    Don't do the task.<br/>
    <span class="italic" style="color:var(--moss);">Spin up someone who will.</span>
  </h2>

  <div class="slot-line mt-12">
    <div class="ex-band">
      <span class="ex-lead">need</span>
      <span class="reel reel-need"><span class="reel-strip" id="stripNeed"></span></span>
      <span class="ex-arrow" aria-hidden="true">⟶</span>
      <span class="ex-lead">Gaia forges</span>
      <span class="reel reel-role"><span class="reel-strip" id="stripRole"></span></span>
    </div>
  </div>

  <p class="muted text-[15px] mt-12 max-w-lg mx-auto leading-relaxed">
    Just say what you want, in plain words. Gaia builds the right specialist for it, every time, then puts it to work. No setup, no prompt wrangling, no fixed menu of bots to pick from.
  </p>
  <a href="#install" class="btn btn-primary mt-8">Get started ↓</a>
</section>

<section class="relative z-10 max-w-5xl mx-auto px-6 pb-10">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-0 border border-[color:var(--rule)]">
    <div class="stat-block border-r border-[color:var(--rule)] p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">∞</div>
      <div class="text-xs muted mt-2 tracking-wide uppercase" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;">Souls forged</div>
    </div>
    <div class="stat-block border-r border-[color:var(--rule)] p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">200+</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">LLMs supported</div>
    </div>
    <div class="stat-block border-r border-[color:var(--rule)] p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">MIT</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">License</div>
    </div>
    <div class="stat-block p-6 text-center">
      <div class="display text-4xl font-bold" style="color:var(--moss);">0</div>
      <div class="text-xs muted mt-2" style="font-family:'Cinzel',serif;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;">Walled gardens</div>
    </div>
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<section id="install" class="relative z-10 max-w-5xl mx-auto px-6 py-24">
  <div class="grid md:grid-cols-12 gap-10">
    <div class="md:col-span-4">
      <p class="eyebrow">I · Begin</p>
      <h2 class="display text-3xl md:text-4xl mt-4 leading-tight tracking-tight">One line.<br/>Any machine.</h2>
      <p class="muted text-[14px] mt-4 leading-relaxed">macOS, Linux, Windows. Bring your own keys, or self-host the whole thing.</p>
    </div>
    <div class="md:col-span-8">
      <div class="shell-wrap">
        <div class="shell-bar">
          <span class="shell-dots" aria-hidden="true">
            <span class="shell-dot r"></span>
            <span class="shell-dot y"></span>
            <span class="shell-dot g"></span>
          </span>
          <span class="shell-title">gaia@earth ~ bash</span>
          <button class="copy-btn" id="copyBtn" onclick="copyInstall()">copy</button>
        </div>
        <div class="vellum">
          <div><span class="p">$</span> <span class="c" id="installCmd">curl -fsSL https://gaia-agent.com/install.sh | bash</span></div>
          <div class="mt-3 dim">→ planting roots ......... <span class="ok">ok</span></div>
          <div class="dim">→ pairing channels ....... <span class="c">whatsapp · telegram · discord</span></div>
          <div class="dim">→ <span class="ok">gaia ready.</span> say hello to your agent.<span class="cursor" aria-hidden="true"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<section class="relative z-10 max-w-5xl mx-auto px-6 py-24">
  <div class="grid md:grid-cols-12 gap-12">
    <div class="md:col-span-5">
      <p class="eyebrow">II · The soul smith</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight">One agent.<br/>Many <span class="italic" style="color:var(--moss);">souls.</span></h2>
      <p class="muted text-[15px] mt-6 leading-relaxed">Gaia itself stays simple. The real trick is in how it hands things off.</p>
      <p class="muted text-[15px] mt-4 leading-relaxed">When something gets <span class="display italic" style="color:var(--ink);font-weight:600;">complex</span>, it passes the work to whichever agent fits best. That's how you get an expert on the job instead of a generalist guessing.</p>
      <p class="muted text-[15px] mt-4 leading-relaxed">And when nothing fits? Gaia just <span class="display italic" style="color:var(--ink);font-weight:600;">makes one</span>. Like the earth it's named after, it shapes a new soul with the right skills, the right model, the right temperament.</p>
      <blockquote class="dictum mt-8">cause why do the task<br/>when you can create a person<br/>that will do it for you?</blockquote>
    </div>
    <div class="md:col-span-7">
      <div class="smith">
        <p class="eyebrow mb-5" style="color:var(--gold);">Worked example</p>
        <div class="mono text-[12px] muted mb-4">"Help me build an A/B gym plan, then a webapp to track progress."</div>
        <div class="smith-grid">
          <div class="node"><span class="brand text-xs" style="color:var(--moss);">GAIA</span><span class="label">→ recognises a complex, two-part request</span></div>
          <div class="arrow">DELEGATES</div>
          <div class="node"><span class="role">soul · gym personal trainer</span><span class="label" style="margin-left:auto;">A/B routine</span></div>
          <div class="node"><span class="role">soul · senior web designer</span><span class="label" style="margin-left:auto;">progress webapp</span></div>
          <div class="arrow">RETURNS</div>
          <div class="node"><span class="brand text-xs" style="color:var(--moss);">GAIA</span><span class="label">→ stitches results, remembers what worked</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="hr-script max-w-5xl mx-auto" />

<section class="relative z-10 max-w-5xl mx-auto px-6 py-24">
  <div class="md:flex items-end justify-between gap-10 mb-14">
    <div>
      <p class="eyebrow">III · What it carries</p>
      <h2 class="display text-4xl md:text-5xl mt-4 leading-[1.05] tracking-tight max-w-xl">Five things every soul inherits.</h2>
    </div>
    <p class="muted text-[14px] max-w-sm mt-4 md:mt-0 leading-relaxed">Gaia and every agent it forges share the same foundation.</p>
  </div>
  <div class="grid md:grid-cols-2">
    <article class="card p-7 border-r-0 border-b-0">
      <svg class="ico" width="36" height="36" viewBox="0 0 32 32"><path d="M5 16h6l3-8 4 16 3-8h6"/><circle cx="11" cy="16" r="1.5"/><circle cx="21" cy="16" r="1.5"/></svg>
      <h3 class="display text-xl mt-5">Tools</h3>
      <p class="muted text-sm mt-3 leading-relaxed">Files, the browser, the network, a shell. Everything it needs to get from <span class="display italic" style="color:var(--ink);">planning</span> to <span class="display italic" style="color:var(--ink);">action</span> without you babysitting it.</p>
    </article>
    <article class="card p-7 border-b-0">
