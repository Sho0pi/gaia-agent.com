<script is:inline>
  function copyInstall() {
    var cmd = document.getElementById('installCmd').textContent;
    var btn = document.getElementById('copyBtn');
    navigator.clipboard.writeText(cmd).then(function() {
      btn.textContent = 'copied!';
      btn.classList.add('copied');
      setTimeout(function() { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 2000);
    });
  }

  // GitHub star count
  fetch('https://api.github.com/repos/sho0pi/gaia')
    .then(function(r) { return r.json(); })
    .then(function(d) {
      var el = document.getElementById('starCount');
      if (el && d.stargazers_count !== undefined) {
        var n = d.stargazers_count;
        el.textContent = n >= 1000 ? (n/1000).toFixed(1) + 'k' : n;
      }
    })
    .catch(function() {}); // repo not public yet, silently fail

  // === Social / tweet wall ===
  // Single source of truth for the campaign hashtag. Change here to rebrand.
  var SOCIAL_TAG = 'gaiaagent';

  (function () {
    var label = document.getElementById('tagLabel');
    if (label) label.textContent = '#' + SOCIAL_TAG;
    var share = document.getElementById('shareX');
    if (share) {
      var text = 'Just let @gaia forge an agent for me. #' + SOCIAL_TAG;
      share.href = 'https://twitter.com/intent/tweet?text=' +
        encodeURIComponent(text) + '&url=' + encodeURIComponent('https://gaia-agent.com');
    }
  })();

  // Tweet wall — dormant. When ready, fetch tweets tagged #<SOCIAL_TAG> (X API or
  // a cached JSON you generate server-side) and pass them here. Stays hidden while empty.
  function renderTweetWall(tweets) {
    var wall = document.getElementById('tweetWall');
    if (!wall || !tweets || !tweets.length) return;
    wall.classList.add('mt-12');
    wall.innerHTML = tweets.map(function (t) {
      return '<figure class="quote-card border-r-0 border-b-0">' +
        '<span class="mark" aria-hidden="true">&ldquo;</span>' +
        '<blockquote>' + t.text + '</blockquote>' +
        '<figcaption class="who"><span class="avatar" aria-hidden="true">' +
        (t.name ? t.name.charAt(0) : '@') + '</span><span><span class="name">' +
        (t.name || '') + '</span><br/><span class="handle">@' + t.handle + '</span></span></figcaption>' +
        '</figure>';
    }).join('');
  }
  // renderTweetWall(await fetch('/tweets.json').then(r => r.json()));  // ← wire later

  // Example slot machine — need flips one row, then the role reel spins and lands on the match.
  (function () {
    var needs = ['a website', 'a workout plan', 'a trip planned', 'your inbox cleared', 'a landing page'];
    var roles = ['a web designer', 'a personal trainer', 'a travel agent', 'a sharp assistant', 'a brand designer'];
    var H = 1.5; // row height in em — must match .reel-strip > span height in CSS
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // A reel whose active row sits centered in a 2-row window (neighbours half-peek above/below).
    function makeReel(strip, items) {
      if (!strip) return null;
      var L = items.length, REPEAT = 14;
      for (var k = 0; k < REPEAT; k++) items.forEach(function (t) {
        var s = document.createElement('span'); s.textContent = t; strip.appendChild(s);
      });
      var pos = L; // start in the 2nd block so a neighbour exists on each side
      function center(p) { strip.style.transform = 'translateY(' + (-((p - 0.5) * H)) + 'em)'; }
      center(pos);
      return {
        pos: pos,
        to: function (idx, durMs, ease, turns) {
          var cur = this.pos % L;
          var np = this.pos + (turns || 0) * L + ((idx - cur + L) % L);
          var self = this;
          if (reduce) { self.pos = L + idx; center(self.pos); return; }
          strip.style.transition = 'transform ' + durMs + 'ms ' + ease;
          void strip.offsetHeight;
          center(np);
          var done = function () {
            strip.removeEventListener('transitionend', done);
            strip.style.transition = 'none';
            self.pos = L + idx; // collapse back into the middle block, no visible jump
            center(self.pos);
          };
          strip.addEventListener('transitionend', done);
        }
      };
    }

    var needReel = makeReel(document.getElementById('stripNeed'), needs);
    var roleReel = makeReel(document.getElementById('stripRole'), roles);
    if (!needReel || !roleReel) return;

    var i = 0;
    setInterval(function () {
      i = (i + 1) % needs.length;
      needReel.to(i, 520, 'cubic-bezier(.2,.85,.25,1)', 0);          // need flips one row
      setTimeout(function () {
        roleReel.to(i, 1200, 'cubic-bezier(.13,.7,.12,1)', 3);       // role spins 3 turns, lands
      }, 600);
    }, 3600);
  })();

  // Verb cycle — no reduced-motion guard, always runs
  var verbs = ['forge', 'delegate', 'teach', 'build'];
  var vi = 0;
  var verbEl = document.getElementById('verb');
  setInterval(function() {
    verbEl.classList.add('out');
    setTimeout(function() {
      vi = (vi + 1) % verbs.length;
      verbEl.textContent = verbs[vi];
      verbEl.classList.remove('out');
      verbEl.classList.add('in');
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          verbEl.classList.remove('in');
        });
      });
    }, 400);
  }, 3500);
</script>

